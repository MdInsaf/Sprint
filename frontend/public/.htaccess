# Sprint Flow - Apache/LiteSpeed configuration for React SPA
# Required for React Router (BrowserRouter) on Hostinger shared hosting.
# All requests that do not match a real file or directory are served index.html,
# which lets the client-side router handle the URL.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route all other requests through the SPA entrypoint
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# Gzip compression for faster load times
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# Cache static assets aggressively (Vite adds content hashes to filenames)
<IfModule mod_expires.c>
  ExpiresActive On

  # Hashed assets (JS/CSS bundles) can be cached for a long time
  <FilesMatch "\.(js|css)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  # Images and fonts can be cached for a month
  <FilesMatch "\.(png|jpg|jpeg|gif|svg|webp|ico|woff|woff2)$">
    ExpiresDefault "access plus 1 month"
  </FilesMatch>

  # HTML should never be stored, otherwise route pages can pin old bundles
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  # Static assets are immutable because Vite fingerprints filenames
  <FilesMatch "\.(js|css)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML must always be fetched fresh after deploys
  <FilesMatch "\.html$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
    Header always unset ETag
    Header always set X-LiteSpeed-Cache-Control "no-cache"
  </FilesMatch>

  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

FileETag None
